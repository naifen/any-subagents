{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "group_id": {
      "type": "string",
      "pattern": "^grp_[A-Za-z0-9_-]+$"
    },
    "session_id": {
      "type": "string",
      "pattern": "^sess_[A-Za-z0-9_-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "cancelled",
        "mixed"
      ]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1"
          },
          "task_id": {
            "type": "string",
            "pattern": "^task_[A-Za-z0-9_-]+$"
          },
          "session_id": {
            "type": "string",
            "pattern": "^sess_[A-Za-z0-9_-]+$"
          },
          "group_id": {
            "type": "string",
            "pattern": "^grp_[A-Za-z0-9_-]+$"
          },
          "mode": {
            "type": "string",
            "enum": [
              "research",
              "plan",
              "diagnose",
              "write",
              "review",
              "verify"
            ]
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "adapter": {
            "type": "string",
            "minLength": 1
          },
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "success_criteria": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "scope": {
            "type": "object",
            "properties": {
              "paths": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "notes": {
                "type": "string"
              }
            },
            "required": [
              "paths"
            ],
            "additionalProperties": false
          },
          "base_ref": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "requested_model": {
            "type": "string",
            "minLength": 1
          },
          "reasoning_level": {
            "type": "string",
            "enum": [
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ]
          },
          "requested_reasoning_level": {
            "type": "string",
            "enum": [
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "max"
            ]
          },
          "reasoning_options": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "allow_fallback": {
            "type": "boolean"
          },
          "permissions": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "sandbox": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_output": {
            "type": "string"
          },
          "verification_commands": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "object",
                  "properties": {
                    "command": {
                      "type": "string",
                      "minLength": 1
                    },
                    "timeout_ms": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": [
                    "command"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          },
          "budgets": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "timeout_ms": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "priority": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "metadata": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "schema_version",
          "task_id",
          "session_id",
          "group_id",
          "mode",
          "goal",
          "adapter",
          "profile",
          "success_criteria"
        ],
        "additionalProperties": false
      }
    },
    "expected_brief_revision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "phase": {
      "type": "string"
    },
    "budgets": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "capacity_preemption_policy": {
      "type": "string",
      "enum": [
        "stop_starting",
        "cancel_running"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schema_version",
    "group_id",
    "session_id",
    "title",
    "status",
    "tasks",
    "expected_brief_revision",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
