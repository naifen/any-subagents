{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "event_id": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "session_id": {
      "type": "string",
      "pattern": "^sess_[A-Za-z0-9_-]+$"
    },
    "group_id": {
      "type": "string",
      "pattern": "^grp_[A-Za-z0-9_-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "attempt_id": {
      "type": "string",
      "pattern": "^att_[A-Za-z0-9_-]+$"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^art_[A-Za-z0-9_-]+$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warning",
        "error"
      ]
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "type",
    "created_at"
  ],
  "additionalProperties": false
}
