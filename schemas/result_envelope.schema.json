{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "attempt_id": {
      "type": "string",
      "pattern": "^att_[A-Za-z0-9_-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "exit_code": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "output": {
            "type": "string"
          }
        },
        "required": [
          "command",
          "status"
        ],
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_id": {
            "type": "string",
            "pattern": "^art_[A-Za-z0-9_-]+$"
          },
          "mime_type": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "type",
          "summary"
        ],
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_brief_updates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          }
        },
        "required": [
          "summary"
        ],
        "additionalProperties": false
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "path",
          "summary"
        ],
        "additionalProperties": false
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "follow_up_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "usage": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schema_version",
    "task_id",
    "attempt_id",
    "status",
    "summary",
    "verification",
    "artifacts",
    "risks",
    "proposed_brief_updates"
  ],
  "additionalProperties": false
}
