{
  "name": "any-subagents",
  "version": "0.1.0",
  "description": "Provider-neutral local control plane for process-backed subagents.",
  "type": "module",
  "bin": {
    "any-subagents": "./dist/cli.js",
    "any-subagents-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "schemas",
    "docs"
  ],
  "scripts": {
    "build": "tsx src/schemas/write-json-schemas.ts && tsup",
    "schemas": "tsx src/schemas/write-json-schemas.ts",
    "dev:cli": "tsx src/cli/main.ts",
    "dev:mcp": "tsx src/mcp/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.4.1",
    "commander": "^14.0.2",
    "fastify": "^5.6.2",
    "nanoid": "^5.1.6",
    "pino": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13"
  }
}
